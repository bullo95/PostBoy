{
  "name": "postboy",
  "version": "1.0.2",
  "description": "Open source API client for Mac, Linux, and Windows",
  "homepage": "https://github.com/brunodomenech/postboy",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "tsc -p tsconfig.electron.json && vite build && electron-builder",
    "build:mac": "npm run build -- --mac",
    "build:win": "npm run build -- --win",
    "build:linux": "npm run build -- --linux",
    "build:linux:x64": "npm run build -- --linux --x64",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "security:audit": "npm audit",
    "security:check": "npm run lint && npm audit"
  },
  "keywords": [
    "api",
    "rest",
    "http",
    "client",
    "postman",
    "electron",
    "open-source"
  ],
  "author": {
    "name": "Bruno Domenech",
    "email": "bruno@postboy.app"
  },
  "license": "MIT",
  "dependencies": {
    "@types/crypto-js": "^4.2.2",
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "electron-store": "^8.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-syntax-highlighter": "^16.1.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.3.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.postboy.app",
    "productName": "Postboy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "build/icon.png",
      "maintainer": "Bruno Domenech <bruno@postboy.app>",
      "vendor": "Postboy",
      "synopsis": "Open source API client",
      "description": "Modern API client for testing REST APIs. Alternative to Postman."
    }
  }
}
